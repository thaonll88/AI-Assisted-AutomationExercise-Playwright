{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["pages/*"],
      "@helpers/*": ["helpers/*"],
      "@appTypes/*": ["types/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "playwright-report", "allure-results", "allure-report", "test-results"]
}
